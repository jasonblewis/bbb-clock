      "Bash(timeout 30 ssh -o ConnectTimeout=8 root@clock.local 'set +e\necho \"======== ps \\(clock process\\) ========\"\nps ax 2>/dev/null | grep -iE \"clock|display\" | grep -v grep\necho \"======== which clock / paths ========\"\nwhich clock 2>/dev/null\nls -l /root/clock/clock /usr/local/bin/clock 2>&1\necho \"======== running exe \\(by pid\\) ========\"\nfor p in $\\(pgrep -f clock 2>/dev/null\\); do echo \"pid $p -> $\\(readlink -f /proc/$p/exe 2>/dev/null\\)\"; echo \"  cmdline: $\\(tr \"\\\\0\" \" \" </proc/$p/cmdline 2>/dev/null\\)\"; done\necho \"======== gpio debug ========\"\ncat /sys/kernel/debug/gpio 2>&1 | head -80\n' 2>&1)",
      "Bash(timeout 30 ssh -o ConnectTimeout=8 root@clock.local 'set +e\necho \"======== clock binary strings \\(spi/build\\) ========\"\nstrings /usr/local/bin/clock 2>/dev/null | grep -iE \"spidev|spi0|spi1|mode|bits|speed|usage|option|-t|gpio|GCC|version|2015\" | head -40\necho \"======== md5 ========\"\nmd5sum /usr/local/bin/clock 2>/dev/null\necho \"======== on-device scripts / source present? ========\"\nls -la /usr/local/bin/ 2>/dev/null | grep -iE \"clock|display|\\\\.sh\"\nfind / -maxdepth 4 -iname \"displayon.sh\" -o -iname \"displayoff.sh\" -o -iname \"start-clock.sh\" 2>/dev/null\necho \"======== init ========\"\nls -la /etc/init.d/ 2>/dev/null | grep -iE \"clock|display\"\ncat /etc/rc.local 2>/dev/null | grep -vE \"^#|^$\"\necho \"======== boot overlay / uEnv ========\"\ncat /boot/uEnv.txt 2>/dev/null | grep -vE \"^#|^$\" | head -30\necho \"======== spidev present ========\"\nls -l /dev/spidev* 2>&1\n' 2>&1)",
      "Bash(timeout 20 ssh -o ConnectTimeout=8 root@clock.local 'cat /usr/local/bin/displayon.sh; echo \"----- displayoff.sh -----\"; cat /usr/local/bin/displayoff.sh; echo \"----- /etc/init.d/clock -----\"; cat /etc/init.d/clock')",
